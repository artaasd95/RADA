# =================================================================
# RADA S3 Storage Configuration
# =================================================================
# Copy this file to .env.s3 and fill in your credentials
# Use: source .env.s3
#
# For AWS S3:
#   S3_ENDPOINT=https://s3.amazonaws.com
#   S3_ACCESS_KEY=AKIA...
#   S3_SECRET_KEY=...
#
# For MinIO or other S3-compatible:
#   S3_ENDPOINT=https://minio.example.com:9000
#   S3_ACCESS_KEY=minioadmin
#   S3_SECRET_KEY=minioadmin
#
# For DigitalOcean Spaces:
#   S3_ENDPOINT=https://nyc3.digitaloceanspaces.com
#   S3_ACCESS_KEY=...
#   S3_SECRET_KEY=...

# ─────────────────────────────────────────────────────────────────
# DATA DOWNLOAD (optional - only if using cloud storage for datasets)
# ─────────────────────────────────────────────────────────────────
S3_DOWNLOAD_ENABLED=false
S3_DOWNLOAD_ENDPOINT=https://s3.amazonaws.com
S3_DOWNLOAD_BUCKET=your-dataset-bucket
S3_DOWNLOAD_PREFIX=datasets/RADA
S3_DOWNLOAD_RETRIES=3

# ─────────────────────────────────────────────────────────────────
# RESULTS UPLOAD (required for backup/sharing)
# ─────────────────────────────────────────────────────────────────
S3_ENDPOINT=https://s3.amazonaws.com
S3_ACCESS_KEY=AKIA...
S3_SECRET_KEY=...
S3_BUCKET=my-rada-results
S3_PROJECT_PREFIX=RADA

# ─────────────────────────────────────────────────────────────────
# UPLOADER BEHAVIOR
# ─────────────────────────────────────────────────────────────────
# Poll interval for checking new files (seconds)
S3_POLL_INTERVAL=30

# Enable/disable gzip compression for text files (.json, .log, .csv)
# Saves ~80-95% storage for logs/metrics
S3_COMPRESS_TEXT=true

# Dry run mode - logs what WOULD be uploaded without actually uploading
S3_DRY_RUN=false

# ─────────────────────────────────────────────────────────────────
# STORAGE STRATEGY (RunPod specific)
# ─────────────────────────────────────────────────────────────────
# Pod storage: ~40GB (use for active training, temp files)
# Network volume: ~95GB (use for persistent data, backups)
# 
# Recommended:
# - Keep training data in pod storage (faster I/O)
# - Stream model checkpoints to network volume + S3
# - Upload results periodically in background

# Network volume mount point (optional)
NETWORK_VOLUME_PATH=/workspace

# Enable periodic cleanup of old runs (keep last N)
CLEANUP_OLD_RUNS=false
KEEP_LAST_N_RUNS=3
