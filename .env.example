RADA_ENV=dev
RADA_LOG_LEVEL=INFO
RADA_EVENT_BUS_MODE=inmemory

RADA_REDIS_URL=redis://localhost:6379/0
RADA_DATABASE_URL=postgresql+asyncpg://rada:rada@localhost:5432/rada
RADA_SQLITE_URL=sqlite:///./rada.db
RADA_API_KEY=

# Change these in real environments.
POSTGRES_USER=rada
POSTGRES_PASSWORD=rada
POSTGRES_DB=rada
RADA_KAFKA_BOOTSTRAP=localhost:9092
RADA_ZMQ_ENDPOINT=tcp://127.0.0.1:5555
RADA_OTEL_ENABLED=false

# Model storage (S13 — local-first base models, adapter output)
RADA_MODEL_CACHE_ROOT=D:/hf-cache
RADA_ADAPTER_STORE_ROOT=D:/rada-adapters
RADA_DISTILLED_ROOT=./data/distilled

# Optional BYOK runtime LLM (usage only — not for training/CI)
RADA_LLM_CONFIG_PATH=configs/llm_mock.yaml
# OPENAI_API_KEY=           # when using configs/llm_cloud.yaml
# MY_LLM_API_KEY=           # when using configs/llm_custom.yaml

# Bucket-native artifact sync (RunPod / S3-compatible)
# BUCKET_ENDPOINT_URL=
# BUCKET_NAME=
# BUCKET_ACCESS_KEY=
# BUCKET_SECRET_KEY=
# BUCKET_PREFIX=rada/
