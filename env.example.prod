# RADA production environment (copy to .env for docker compose)

RADA_ENV=production
RADA_PORT=8000
RADA_API_KEY=CHANGE_ME
RADA_POSTGRES_PASSWORD=CHANGE_ME
RADA_DATA_STORE_MODE=sqlite
RADA_SQLITE_URL=sqlite:////app/data/rada.db
RADA_EVENT_BUS_MODE=redis
RADA_REDIS_URL=redis://redis:6379/0
RADA_REASONER_MODE=mock
RADA_OTEL_ENABLED=false
RADA_API_URL=http://localhost:8000
RADA_DASHBOARD_PORT=5173
RADA_AUDIT_DB_PATH=/app/data/rada_audit.db
RADA_FEEDBACK_DB_PATH=/app/data/rada_feedback.db
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME
